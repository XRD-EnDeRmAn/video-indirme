{
  "version": 2,
  "builds": [
    { "src": "api/info.js",     "use": "@vercel/node" },
    { "src": "api/download.js", "use": "@vercel/node" },
    { "src": "index.html",      "use": "@vercel/static" },
    { "src": "style.css",       "use": "@vercel/static" },
    { "src": "app.js",          "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/info",     "dest": "/api/info.js" },
    { "src": "/api/download", "dest": "/api/download.js" },
    { "src": "/style.css",    "dest": "/style.css" },
    { "src": "/app.js",       "dest": "/app.js" },
    { "src": "/(.*)",         "dest": "/index.html" }
  ],
  "functions": {
    "api/info.js":     { "maxDuration": 60 },
    "api/download.js": { "maxDuration": 60 }
  }
}
