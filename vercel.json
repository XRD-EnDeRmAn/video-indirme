{
  "version": 2,
  "routes": [
    { "src": "/api/info", "dest": "/api/info.js" },
    { "src": "/api/download", "dest": "/api/download.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "functions": {
    "api/info.js": {
      "maxDuration": 60
    },
    "api/download.js": {
      "maxDuration": 60
    }
  }
}
